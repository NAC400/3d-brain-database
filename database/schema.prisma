// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  role      UserRole @default(RESEARCHER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Research data associations
  researchStudies ResearchStudy[]
  annotations     Annotation[]
  
  @@map("users")
}

model BrainStructure {
  id            String  @id @default(cuid())
  name          String
  anatomicalId  String  @unique
  description   String?
  parentId      String?
  
  // 3D coordinates and properties
  positionX     Float
  positionY     Float
  positionZ     Float
  scaleX        Float   @default(1.0)
  scaleY        Float   @default(1.0)
  scaleZ        Float   @default(1.0)
  
  // Model file references
  modelPath     String?
  texturePath   String?
  
  // Hierarchy
  parent        BrainStructure? @relation("BrainStructureHierarchy", fields: [parentId], references: [id])
  children      BrainStructure[] @relation("BrainStructureHierarchy")
  
  // Research associations
  researchData  ResearchData[]
  annotations   Annotation[]
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  @@map("brain_structures")
}

model ResearchStudy {
  id          String   @id @default(cuid())
  title       String
  description String?
  methodology StudyType
  authorId    String
  
  // Study metadata
  startDate   DateTime?
  endDate     DateTime?
  participants Int?
  
  // Associations
  author      User           @relation(fields: [authorId], references: [id])
  researchData ResearchData[]
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@map("research_studies")
}

model ResearchData {
  id              String   @id @default(cuid())
  studyId         String
  structureId     String
  
  // Data content
  dataType        DataType
  values          Json     // Flexible JSON storage for various data types
  metadata        Json?    // Additional metadata
  
  // Temporal data
  timepoint       DateTime?
  duration        Int?     // Duration in seconds
  
  // Quality metrics
  confidence      Float?   @default(1.0)
  significance    Float?
  
  // Associations
  study           ResearchStudy   @relation(fields: [studyId], references: [id])
  brainStructure  BrainStructure  @relation(fields: [structureId], references: [id])
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  @@map("research_data")
}

model Annotation {
  id          String   @id @default(cuid())
  structureId String
  authorId    String
  
  // Annotation content
  title       String
  content     String
  annotationType AnnotationType @default(NOTE)
  
  // 3D position for annotation marker
  positionX   Float
  positionY   Float
  positionZ   Float
  
  // Visual properties
  color       String?  @default("#3b82f6")
  isVisible   Boolean  @default(true)
  
  // Associations
  brainStructure BrainStructure @relation(fields: [structureId], references: [id])
  author         User           @relation(fields: [authorId], references: [id])
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@map("annotations")
}

model ModelAsset {
  id          String   @id @default(cuid())
  name        String
  description String?
  
  // File information
  filePath    String
  fileSize    Int
  format      String   // gltf, obj, fbx, etc.
  
  // Asset metadata
  vertices    Int?
  polygons    Int?
  textures    String[] // Array of texture file paths
  
  // Version control
  version     String   @default("1.0")
  isActive    Boolean  @default(true)
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@map("model_assets")
}

// Enums
enum UserRole {
  ADMIN
  RESEARCHER
  VIEWER
}

enum StudyType {
  FMRI
  DTI
  PET
  CT
  MRI
  EEG
  MEG
  BEHAVIORAL
  OTHER
}

enum DataType {
  ACTIVATION
  CONNECTIVITY
  STRUCTURAL
  FUNCTIONAL
  METABOLIC
  ELECTRICAL
  BEHAVIORAL_SCORE
  STATISTICAL
  OTHER
}

enum AnnotationType {
  NOTE
  OBSERVATION
  HYPOTHESIS
  FINDING
  LANDMARK
  REGION_OF_INTEREST
} 